{
  "agy": {
    "type": "custom",
    "dir": "agy",
    "name": "Antigravity (inline)",
    "label": "AGY (Antigravity)",
    "description": "Gemini models via Antigravity CLI OAuth",
    "defaultModel": "gemini-3.5-flash",
    "models": [
      "gemini-3.5-flash",
      "gemini-3-pro",
      "gemini-3-pro-thinking",
      "gemini-2.5-pro",
      "gemini-2.5-flash"
    ],
    "port": 8318,
    "envKey": "GROK_AGY_PROXY_API_KEY",
    "binaryName": "agy",
    "logo": "gemini_logo.png"
  },
  "codex": {
    "type": "custom",
    "dir": "codex",
    "name": "Codex (inline)",
    "label": "Codex",
    "description": "Codex models via the Codex CLI OAuth",
    "defaultModel": "gpt-5.5",
    "models": [
      "gpt-5.5",
      "gpt-5.4",
      "gpt-5.4-mini",
      "gpt-5.3-codex",
      "gpt-5.2"
    ],
    "port": 8319,
    "envKey": "GROK_CODEX_PROXY_API_KEY",
    "binaryName": "codex",
    "logo": "codex_logo.png"
  },
  "deepseek": {
    "type": "passthrough",
    "name": "DeepSeek",
    "label": "DeepSeek",
    "description": "DeepSeek API direct compatible-mode integration",
    "defaultModel": "deepseek-v4-flash",
    "baseUrl": "https://api.deepseek.com",
    "envKey": "DEEPSEEK_API_KEY",
    "logo": "deepseek_logo.png"
  },
  "openrouter": {
    "type": "passthrough",
    "name": "OpenRouter",
    "label": "OpenRouter",
    "description": "Unified gateway to hundreds of models across providers via the OpenRouter API",
    "defaultModel": "openrouter/auto",
    "baseUrl": "https://openrouter.ai/api/v1",
    "envKey": "OPENROUTER_API_KEY",
    "logo": "openrouter_logo.png"
  },
  "qwen": {
    "type": "passthrough",
    "name": "Qwen Coder",
    "label": "Qwen (Alibaba)",
    "description": "Alibaba DashScope Qwen models",
    "defaultModel": "qwen2.5-coder-32b-instruct",
    "baseUrl": "https://dashscope-intl.aliyuncs.com/compatible-mode/v1",
    "envKey": "DASHSCOPE_API_KEY",
    "logo": "qwen_logo.png"
  }
}
