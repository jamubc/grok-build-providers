{
  "name": "open-grok-build",
  "version": "1.0.0",
  "description": "Interactive TUI and all-in-one connector installer for Grok Build (Gemini/Antigravity, Codex, DeepSeek, and Qwen)",
  "main": "tui.js",
  "bin": {
    "open-grok-build": "./tui.js",
    "grok-agy": "./agy/bin/grok-agy.js",
    "grok-codex": "./codex/bin/grok-codex.js",
    "grok-deepseek": "./deepseek/bin/grok-deepseek.js",
    "grok-qwen": "./qwen/bin/grok-qwen.js"
  },
  "scripts": {
    "start": "node tui.js",
    "install-all": "node tui.js all"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "author": "jamubc",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jamubc/open-grok-build.git"
