{
  "name": "grok-build-providers",
  "version": "1.1.0",
  "description": "Interactive TUI and all-in-one connector installer for Grok Build (Gemini/Antigravity, Codex, DeepSeek, Qwen, and OpenRouter)",
  "main": "tui.js",
  "bin": {
    "grok-build-providers": "./tui.js",
    "grok-agy": "./bins/grok-agy.js",
    "grok-codex": "./bins/grok-codex.js",
    "grok-deepseek": "./bins/grok-deepseek.js",
    "grok-openrouter": "./bins/grok-openrouter.js",
    "grok-qwen": "./bins/grok-qwen.js"
  },
  "scripts": {
    "start": "node tui.js",
    "install-all": "node tui.js all",
    "build:manifest": "node scripts/aggregate-manifest.js",
    "build:bins": "node scripts/generate-bins.js",
    "build": "npm run build:manifest && npm run build:bins",
    "check:manifest": "node scripts/aggregate-manifest.js --check"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "author": "jamubc",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jamubc/grok-build-providers.git"
  },
  "files": [
    "tui.js",
    "bins",
    "providers",
    "scripts",
    "README.md",
    "CONTRIBUTING.md",
    "CHANGELOG.md",
    "LICENSE"
  ]
}
